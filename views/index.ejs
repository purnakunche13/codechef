<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>CodeChef Rating Lookup</title>
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
  <main class="container">

    <h1>⚡ CodeChef Rating Lookup</h1>

    <!-- FORM -->
    <form action="/lookup" method="POST">
      <textarea name="usernames" rows="4" placeholder="Enter usernames..."><%= usernames %></textarea>
      <button type="submit" class="btn-primary">Lookup</button>
    </form>

    <% if (error) { %>
      <p style="color:red;"><%= error %></p>
    <% } %>

    <% if (results && results.length > 0) { %>

    <!-- FILTERS -->
    <div class="filters">
      <input type="text" id="searchUser" placeholder="Search username...">
      <input type="text" id="searchContest" placeholder="Search contest...">

      <select id="sortBy">
        <option value="">Sort By</option>
        <option value="rating">Rating</option>
        <option value="rank">Global Rank</option>
        <option value="change">Rating Change</option>
      </select>

      <select id="order">
        <option value="desc">Descending</option>
        <option value="asc">Ascending</option>
      </select>
      <button type="button" onclick="applyFilters()">Apply</button>
      <button type="button" onclick="resetFilters()">Reset</button>
    </div>

    <!-- TABLE -->
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Username</th>
          <th>Rating</th>
          <th>Global Rank</th>
          <th>Country Rank</th>
          <th>Last Contest</th>
          <th>Change</th>
        </tr>
      </thead>

      <tbody id="tableBody">
        <% results.forEach((user, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= user.username %></td>
          <td class="cell-rating"><%= user.rating %></td>
          <td class="cell-rank"><%= user.globalRank %></td>
          <td class="cell-rank"><%= user.countryRank %></td>
          <td><%= user.lastContest %></td>
          <td class="cell-change"><%= user.ratingChange %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>

    <% } %>

  </main>

  <footer>Developed by PurnaKunche</footer>

  <script>
    function getNumber(text) {
      return parseInt(text.replace(/[^\d-]/g, "")) || 0;
    }

    function applyFilters() {
      const sortBy = document.getElementById("sortBy").value;
      const order = document.getElementById("order").value;
      const changeFilter = document.getElementById("changeFilter").value;

      const searchUser = document.getElementById("searchUser").value.toLowerCase();
      const searchContest = document.getElementById("searchContest").value.toLowerCase();

      const table = document.getElementById("tableBody");
      let rows = Array.from(table.querySelectorAll("tr"));

      rows = rows.filter(row => {
        const username = row.children[1].innerText.toLowerCase();
        const contest = row.children[5].innerText.toLowerCase();
        const change = row.querySelector(".cell-change").innerText;

        if (searchUser && !username.includes(searchUser)) return false;
        if (searchContest && !contest.includes(searchContest)) return false;

        if (changeFilter === "positive" && !change.includes("+")) return false;
        if (changeFilter === "negative" && !change.includes("-")) return false;

        return true;
      });

      rows.sort((a, b) => {
        let valA = 0, valB = 0;

        if (sortBy === "rating") {
          valA = getNumber(a.querySelector(".cell-rating").innerText);
          valB = getNumber(b.querySelector(".cell-rating").innerText);
        }

        if (sortBy === "rank") {
          valA = getNumber(a.querySelectorAll(".cell-rank")[0].innerText) || Infinity;
          valB = getNumber(b.querySelectorAll(".cell-rank")[0].innerText) || Infinity;
        }

        if (sortBy === "change") {
          valA = getNumber(a.querySelector(".cell-change").innerText);
          valB = getNumber(b.querySelector(".cell-change").innerText);
        }

        return order === "asc" ? valA - valB : valB - valA;
      });

      table.innerHTML = "";
      rows.forEach((row, index) => {
        row.children[0].innerText = index + 1;
        table.appendChild(row);
      });
    }

    function resetFilters() {
      document.getElementById("sortBy").value = "";
      document.getElementById("order").value = "desc";
      document.getElementById("changeFilter").value = "";
      document.getElementById("searchUser").value = "";
      document.getElementById("searchContest").value = "";

      const table = document.getElementById("tableBody");
      const rows = Array.from(table.querySelectorAll("tr"));

      rows.forEach((row, index) => {
        row.style.display = "";
        row.children[0].innerText = index + 1;
      });
    }
  </script>

</body>
</html>
